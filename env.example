# ── Fast2SMS ──────────────────────────────────────────────────────────────────
# Get from: https://www.fast2sms.com → Dashboard → Dev API
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# ── Google Service Account ────────────────────────────────────────────────────
# Paste the ENTIRE contents of your service account JSON as a single line here.
# Get from: Google Cloud Console → IAM → Service Accounts → Keys → JSON
# Tip: cat your-file.json | python3 -c "import sys,json; print(json.dumps(json.load(sys.stdin)))"
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"..."}

# ── Google Sheet ──────────────────────────────────────────────────────────────
# The long ID in your sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# ── Render Web App ────────────────────────────────────────────────────────────
# Your Render deployment URL (no trailing slash)
# e.g. https://rent-reminder.onrender.com
CONFIRMATION_BASE_URL=https://your-app.onrender.com

# ── App Config ────────────────────────────────────────────────────────────────
APARTMENT_NAME=Mandakini Garden
REMINDER_STOP_DAY=15
